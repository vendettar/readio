# Readio Cloud API - Local Development Environment Template
# Usage: cp .env.example .env
# after setup: set -a; source .env; set +a; go run .

# Database Path (Absolute path required for some modules)
READIO_CLOUD_DB_PATH="REPLACE_WITH_ABSOLUTE_PATH"

# Transcript Asset Root (MUST be an absolute path)
READIO_PODCAST_TRANSCRIPT_ASSET_ROOT="REPLACE_WITH_ABSOLUTE_PATH"

READIO_LOKI_LOG_LEVEL="debug"

# Podcast Index Credentials (Required for discovery features)
# Get yours at: https://api.podcastindex.org/
PODCAST_INDEX_API_KEY=""
PODCAST_INDEX_API_SECRET=""
PODCAST_INDEX_USER_AGENT="Readio/1.0 (Dev)"

# CORS: Allow local frontend to access this API
# Default Vite port is 5173
READIO_DISCOVERY_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"
READIO_PROXY_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000"

# Optional: Port configuration (default is 8080)
# PORT=8080

# --- Observability & Deployment ---

# Deployment Environment (e.g., "production", "develop")
# Set to "develop" for local testing to avoid polluting production metrics.
READIO_DEPLOY_ENV="develop"

# Grafana Loki - Logs
# Found in Grafana Cloud -> Loki -> "Send Logs"
READIO_GRAFANA_LOKI_URL=""
READIO_GRAFANA_LOKI_USER=""
READIO_GRAFANA_LOKI_TOKEN=""

# Grafana OTLP - Traces & Metrics
# Found in Grafana Cloud -> OpenTelemetry -> "Configure SDK"
# READIO_GRAFANA_OTLP_ENDPOINT: e.g. https://otlp-gateway-prod-us-west-0.grafana.net
READIO_GRAFANA_OTLP_ENDPOINT=""
# READIO_GRAFANA_OTLP_HEADERS: format "Authorization=Basic%20XXXXX"
READIO_GRAFANA_OTLP_HEADERS=""

# Alternative OTLP Auth (Basic Auth fallback)
READIO_GRAFANA_OTLP_INSTANCE_ID=""
READIO_GRAFANA_OTLP_TOKEN=""

# --- Frontend Configuration (Served via /api/v1/config) ---
# These must be set in the backend environment to be passed to the UI.
VITE_GRAFANA_FARO_URL=""
VITE_GRAFANA_FARO_APP_NAME="readio-cloud-ui"
VITE_GRAFANA_FARO_ENV="develop"
VITE_GRAFANA_FARO_SAMPLE_RATE="1.0"
