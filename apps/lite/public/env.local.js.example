/**
 * Readio Runtime Configuration - LOCAL OVERRIDES
 * 
 * This file is for YOUR PERSONAL configuration and is NOT committed to Git.
 * 
 * USAGE:
 * 1. Rename this file from env.local.js.example to env.local.js
 * 2. Customize the values below
 * 3. The app will automatically merge these overrides with public/env.js
 * 
 * PRIORITY:
 * - env.local.js (this file) takes priority over env.js
 * - Only define values you want to override (partial override supported)
 */

window.__READIO_ENV__ = {
  ...window.__READIO_ENV__,

  // --- Custom CORS Proxy (Recommended for Production) ---
  // Custom proxies ALWAYS use POST with JSON body { "url": "TARGET" } (no GET fallback).
  // To use your own proxy (Cloudflare Worker, Nginx, etc):
  // 1. Proxy endpoint receives POST with JSON body: { "url": "https://example.com/feed.xml" }
  // 2. Returns RAW content (passthrough), NOT wrapped in JSON.
  //
  // See agent/instructions/lite/084-cf-worker.js for reference implementation.
  //
  // Uncomment and configure:
  READIO_CORS_PROXY_URL: 'https://your-worker.workers.dev',

  // --- Custom Proxy: Authentication (Public Credential) ---
  // IMPORTANT: Frontend config is PUBLIC, not secret storage.
  // READIO_CORS_PROXY_AUTH_VALUE is a non-secret public credential used for
  // abuse control and routing policy (not secrecy).
  //
  // For true secret protection, move secrets to server-side proxy.
  //
  // Header name is fixed by contract: x-proxy-token
  // Example:
  // READIO_CORS_PROXY_AUTH_HEADER: 'x-proxy-token',
  // READIO_CORS_PROXY_AUTH_VALUE: 'your-public-token-here',

  // --- Speech-to-Text (ASR) Configuration ---
  // To enable cloud-accelerated transcription (Groq / Qwen):
  // 1. Get an API key from the provider (e.g. https://console.groq.com/)
  //
  // READIO_ASR_PROVIDER: 'groq', // Supported: groq, qwen, deepgram, volcengine
  // READIO_ASR_MODEL: 'whisper-large-v3',
  // READIO_ASR_API_KEY: 'your-api-key-here',
  //
  // Volcengine example (use appId:accessToken format):
  // READIO_ASR_PROVIDER: 'volcengine',
  // READIO_ASR_MODEL: 'bigmodel',
  // READIO_ASR_API_KEY: 'your-app-id:your-access-token',
  //
  // Which providers to enable/disable? (comma-separated, supports groq, qwen, deepgram, volcengine)
  // Example 1 (Enable ONLY groq):
  // READIO_ENABLED_ASR_PROVIDERS: 'groq',
  //
  // Example 2 (Enable all EXCEPT qwen):
  // READIO_ENABLED_ASR_PROVIDERS: 'all',  // or '*' or empty
  // READIO_DISABLED_ASR_PROVIDERS: 'qwen',
  //
  // --- LLM Services (Translation & Parsing) ---
  // READIO_OPENAI_API_KEY: 'sk-your-openai-key-here',

  // --- Example: Custom English Dictionary API ---
  // READIO_EN_DICTIONARY_API_URL: 'https://your-dict-api.com/api/entries/',

  // READIO_DEFAULT_PODCAST_CONTENT_COUNTRY: 'us',
  // READIO_DEFAULT_LANGUAGE: 'en', // Supported: en/zh/ja/ko/de/es

  // --- Example: Development Tweaks ---
  // READIO_MAX_AUDIO_SIZE_MB: 500,
  // READIO_MAX_AUDIO_CACHE_GB: 10,
  // --- Example: Custom Timeouts (ms) ---
  // READIO_PROXY_TIMEOUT_MS: 15000,
  // READIO_DIRECT_TIMEOUT_MS: 3000,
};
