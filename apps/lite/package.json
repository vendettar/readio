{
  "name": "@readio/lite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "cross-env VITE_USE_MOCK_DATA=false vite",
    "dev:lan": "cross-env VITE_USE_MOCK_DATA=false VITE_DEV_HOST_ALL=1 vite",
    "dev:mock": "cross-env VITE_USE_MOCK_DATA=true vite",
    "dev:e2e": "cross-env VITE_E2E=true vite --port 5173 --strictPort",
    "build": "tsc -b && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:db-guard": "node scripts/check-db-guard.js",
    "lint:selectors": "bash scripts/enforce-selectors.sh",
    "lint:route-guards": "node scripts/check-route-country-guards.js",
    "lint:legacy-route-ban": "node scripts/check-legacy-podcast-route-ban.js",
    "lint:all": "pnpm lint && pnpm lint:db-guard && pnpm lint:selectors && pnpm lint:route-guards && pnpm lint:legacy-route-ban && pnpm i18n:check",
    "format": "biome check --write .",
    "check": "biome check .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "vitest run && playwright test",
    "check-size": "node scripts/check-bundle-size.js",
    "i18n:check": "node --import tsx scripts/audit-i18n.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@floating-ui/react": "^0.27.19",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.6",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@readio/core": "workspace:*",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-router": "^1.157.16",
    "@tanstack/router-devtools": "^1.157.16",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "dexie": "^4.2.1",
    "dompurify": "^3.3.1",
    "framer-motion": "^12.29.2",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^0.563.0",
    "music-metadata": "^11.11.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.71.1",
    "react-hotkeys-hook": "^5.2.3",
    "react-i18next": "^16.5.4",
    "react-virtuoso": "^4.18.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "web-vitals": "^5.1.0",
    "workbox-window": "^7.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@playwright/test": "^1.58.0",
    "@tailwindcss/postcss": "^4.1.18",
    "@tanstack/query-core": "^5.90.20",
    "@tanstack/router-plugin": "^1.157.16",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "autoprefixer": "^10.4.23",
    "cross-env": "^10.1.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^27.4.0",
    "msw": "^2.12.7",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^6.0.5",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "turbo": "^2.8.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18"
  }
}
