{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "startServerCommand": "pnpm preview",
      "url": ["http://localhost:4173"]
    },
    "upload": { "target": "temporary-public-storage" },
    "assert": {
      "preset": "lighthouse:no-pwa",
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.9 }]
      }
    }
  }
}
