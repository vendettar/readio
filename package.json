{
  "name": "readio-monorepo",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.28.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint && pnpm --filter @readio/lite lint:db-guard && pnpm --filter @readio/lite i18n:check && pnpm --filter @readio/lite lint:selectors && pnpm --filter @readio/lite lint:route-guards && pnpm --filter @readio/lite lint:legacy-route-ban",
    "typecheck": "turbo typecheck && pnpm --filter @readio/core build",
    "format": "turbo format",
    "test": "turbo test",
    "lite:dev": "pnpm --filter @readio/lite dev",
    "lite:build": "pnpm --filter @readio/lite build",
    "lite:lint": "pnpm --filter @readio/lite lint",
    "lite:typecheck": "pnpm --filter @readio/lite typecheck",
    "lite:test": "pnpm --filter @readio/lite test",
    "lite:test:run": "pnpm --filter @readio/lite test:run",
    "lite:e2e": "pnpm --filter @readio/lite test:e2e",
    "lite:e2e:ui": "pnpm --filter @readio/lite test:e2e:ui",
    "cloud:build": "pnpm --filter @readio/cloud-ui build",
    "cloud:lint": "pnpm --filter @readio/cloud-api lint",
    "cloud:dev": "pnpm run cloud:build && pnpm --filter @readio/cloud-api dev"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@lhci/cli": "^0.15.1",
    "license-checker-rseidelsohn": "^4.4.2",
    "turbo": "latest"
  },
  "pnpm": {
    "overrides": {
      "basic-ftp": "^5.2.0",
      "next@>=16.1.0-canary.0 <16.1.5": "^16.1.5",
      "@isaacs/brace-expansion": "^5.0.1",
      "minimatch@<3.1.4": "^3.1.4",
      "minimatch@>=5.0.0 <5.1.8": "^5.1.8",
      "minimatch@>=9.0.0 <9.0.7": "^9.0.7",
      "minimatch@>=10.0.0 <10.2.3": "^10.2.3",
      "rollup@<2.80.0": "^2.80.0",
      "rollup@>=4.0.0 <4.59.0": "^4.59.0",
      "serialize-javascript": "^7.0.3",
      "music-metadata": "^11.12.3"
    }
  }
}
