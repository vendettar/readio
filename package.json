{
  "name": "readio-monorepo",
  "private": true,
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "turbo format",
    "test": "turbo test",
    "cloud:build": "pnpm --filter @readio/cloud-ui build",
    "cloud:lint": "pnpm --filter @readio/cloud-api lint",
    "cloud:dev": "sh -lc 'if [ -f ./.env.cloud.local.sh ]; then . ./.env.cloud.local.sh; fi; pnpm run cloud:build && pnpm --filter @readio/cloud-api dev'"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@lhci/cli": "^0.15.1",
    "license-checker-rseidelsohn": "^4.4.2",
    "turbo": "latest"
  }
}
